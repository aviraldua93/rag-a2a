{
  "name": "rag-a2a",
  "version": "0.1.0",
  "description": "Production-grade RAG pipeline exposed as an A2A agent. Hybrid search, reranking, evaluation, streaming.",
  "author": "Aviral Dua",
  "license": "MIT",
  "type": "module",
  "main": "src/server/index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/aviraldua93/rag-a2a.git"
  },
  "homepage": "https://github.com/aviraldua93/rag-a2a",
  "bugs": {
    "url": "https://github.com/aviraldua93/rag-a2a/issues"
  },
  "keywords": [
    "rag",
    "retrieval-augmented-generation",
    "a2a",
    "agent-to-agent",
    "vector-search",
    "hybrid-search",
    "bm25",
    "reranking",
    "qdrant",
    "embeddings",
    "llm",
    "ai-agent",
    "typescript",
    "bun"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run --hot src/server/index.ts",
    "start": "bun run src/server/index.ts",
    "test": "bun test tests/setup.test.ts tests/unit/",
    "test:e2e": "bunx playwright test",
    "typecheck": "bun x tsc --noEmit",
    "ingest": "bun run src/ingestion/pipeline.ts",
    "evaluate": "bun run src/evaluation/runner.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.17.0",
    "openai": "^6.33.0",
    "undici-types": "^8.0.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.11",
    "bun-types": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
